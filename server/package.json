{
  "name": "no-code-bot-server",
  "version": "1.0.0",
  "description": "Mock API server for no-code-bot",
  "main": "server.js",
  "scripts": {
  "start": "node server.js",
  "start:manager": "tsx src/engineManager.ts",
  "dev:manager": "tsx watch src/engineManager.ts",
  "typecheck:manager": "tsc -p tsconfig.json --noEmit",
  "build": "tsc"
},
  "dependencies": {
    "fast-json-patch": "^3.1.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.0",
    "@types/node-fetch": "^2.6.13",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
